@startuml LogisticsCompanyUseCase
left to right direction
skinparam packageStyle rectangle

actor "Client" as client
actor "Office Clerk" as clerk
actor "Courier" as courier
actor "System Admin" as admin
actor "Anonymous User" as guest

package "Logistics Company System" {

  usecase "Track Shipment (Public)" as UC_TrackPublic
  usecase "Login" as UC_Login
  usecase "Register (Self)" as UC_Register

  usecase "Register Shipment" as UC_RegShipment
  usecase "Edit/Cancel Shipment (Pending)" as UC_EditShipment
  usecase "View Own Shipments" as UC_ViewOwn

  usecase "View All Shipments" as UC_ViewAll
  usecase "Update Shipment Status" as UC_UpdateStatus
  usecase "Assign Courier (Pickup/Delivery)" as UC_AssignCourier

  usecase "View My Tasks (Pickups/Deliveries)" as UC_MyTasks

  usecase "Manage Employees & Offices" as UC_ManageStaff
  usecase "View Revenue Reports" as UC_Reports
}

guest --> UC_TrackPublic
guest --> UC_Login
guest --> UC_Register

client --> UC_Login
client --> UC_Register
client --> UC_RegShipment
client --> UC_EditShipment
client --> UC_ViewOwn
client --> UC_TrackPublic

clerk --> UC_Login
clerk --> UC_ViewAll
clerk --> UC_RegShipment
clerk --> UC_EditShipment
clerk --> UC_UpdateStatus
clerk --> UC_AssignCourier

courier --> UC_Login
courier --> UC_MyTasks
courier --> UC_UpdateStatus
courier --> UC_EditShipment : "If assigned for pickup"

admin --> UC_Login
admin --> UC_ManageStaff
admin --> UC_Reports
admin --> UC_ViewAll

@enduml
